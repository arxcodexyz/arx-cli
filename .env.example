# ArxCode CLI — environment variables
# Copy to .env and fill in your keys: cp .env.example .env
# .env is gitignored — NEVER commit real keys.

# ── Provider API Keys (BYOK) ────────────────────────────────────────

# Groq (free tier!) — https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# DeepSeek ($0.14/M tokens) — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk_your_key_here

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# xAI / Grok — https://console.x.ai
XAI_API_KEY=xai-your-key-here

# Google Gemini (free tier!) — https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIzaSy-your-key-here

# ── Optional ────────────────────────────────────────────────────────

# Default provider/model
# ARX_PROVIDER=groq
# ARX_MODEL=llama-4-scout

# Custom OpenAI-compatible endpoint (e.g. local LLM)
# ARX_BASE_URL=http://localhost:11434/v1
